# =============================================================================
# Gaana Discovery AI Backend - Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port for the backend server (default: 3001)
PORT=3001

# Environment: development | production
NODE_ENV=development

# Frontend URL(s) for CORS - comma-separated for multiple origins
FRONTEND_URL=http://localhost:3000,http://localhost:3002

# -----------------------------------------------------------------------------
# Groq AI API Configuration
# -----------------------------------------------------------------------------
# Groq API key for LLM analysis (required for AI features)
GROQ_API_KEY=your_groq_api_key_here

# -----------------------------------------------------------------------------
# Google Play Store Scraper
# -----------------------------------------------------------------------------
# Android app ID for Gaana on Google Play
GOOGLE_PLAY_APP_ID=com.gaana

# -----------------------------------------------------------------------------
# Apple App Store Scraper
# -----------------------------------------------------------------------------
# iOS app ID for Gaana on App Store India
APP_STORE_APP_ID=1491726408
APP_STORE_COUNTRY=in

# -----------------------------------------------------------------------------
# Reddit Scraper
# -----------------------------------------------------------------------------
# Reddit API credentials for higher rate limits (optional for public API)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=GaanaDiscoveryAI/5.0

# -----------------------------------------------------------------------------
# Scraping Configuration
# -----------------------------------------------------------------------------
# Delay between requests to avoid rate limiting (milliseconds)
SCRAPE_DELAY_MS=1500

# Maximum pages to fetch per source during scraping
MAX_PAGES_PER_SOURCE=5

# HTTP request timeout for scrapers (milliseconds)
REQUEST_TIMEOUT_MS=15000